# =============================================================
#   TRIKAL VAANI — Environment Variables
#   File: .env.example
#   Copy to .env.local (Vercel) and set in Render dashboard
# =============================================================

# ── Render (FastAPI) — set these in Render Dashboard ─────────
TRIKAL_API_KEY=your-secret-key-here
EPHE_PATH=/app/ephe_data
ALLOWED_ORIGINS=https://trikalvaani.com,https://www.trikalvaani.com

# ── Vercel (Next.js) — set in Vercel Dashboard ───────────────
# Internal server-side URL for ephemeris service (Render URL)
EPHE_API_URL=https://trikal-vaani-ephemeris.onrender.com
# Secret key must match TRIKAL_API_KEY above
EPHE_API_KEY=your-secret-key-here

# Public URL (if calling from client — optional, prefer server-side)
# NEXT_PUBLIC_EPHE_API_URL=https://trikal-vaani-ephemeris.onrender.com

# ── Supabase ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Gemini (AI features) ─────────────────────────────────────
GEMINI_API_KEY=your-gemini-key

# ── Misc ─────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://trikalvaani.com
